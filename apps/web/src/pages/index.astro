---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fiber L402 — Pay-per-Article Content">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient glow -->
    <div class="pointer-events-none absolute -top-32 left-1/2 h-120 w-160 -translate-x-1/2 rounded-full bg-accent/8 blur-[100px]" />

    <div class="relative mx-auto max-w-4xl px-6 pb-24 pt-20 text-center sm:pt-28 sm:pb-32">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface-2/60 px-4 py-1.5 text-sm text-text-secondary">
        <span class="h-1.5 w-1.5 rounded-full bg-success animate-pulse" />
        Built on Fiber Network &amp; CKB
      </div>

      <h1 class="mx-auto max-w-2xl text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
        Premium Content,<br />
        <span class="text-accent">Pay Per Article</span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-text-secondary sm:text-xl">
        Access in-depth articles about Fiber Network, Bitcoin Lightning, and L402 protocol. Pay only for what you read — powered by CKB payment channels.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/articles"
          class="inline-flex items-center gap-2 rounded-xl bg-accent px-6 py-3.5 text-base font-semibold text-surface-0 no-underline transition-all duration-200 hover:bg-accent-hover hover:shadow-[0_0_32px_oklch(0.75_0.12_85/0.3)]"
        >
          Browse Articles
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="https://github.com/nickg/fiber-l402"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl border border-border px-6 py-3.5 text-base font-medium text-text-secondary no-underline transition-colors duration-200 hover:border-border-hover hover:bg-surface-2 hover:text-text-primary"
        >
          View Source
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="border-t border-border bg-surface-1/30">
    <div class="mx-auto grid max-w-5xl gap-px px-6 py-20 sm:grid-cols-3">
      <!-- Feature 1 -->
      <div class="group rounded-2xl p-8 transition-colors duration-200 hover:bg-surface-2/50">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-accent">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold">Instant Payments</h3>
        <p class="text-sm leading-relaxed text-text-secondary">
          Pay through Fiber Network payment channels — settle in milliseconds, not minutes.
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="group rounded-2xl p-8 transition-colors duration-200 hover:bg-surface-2/50">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-info/10 text-info">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold">L402 Protocol</h3>
        <p class="text-sm leading-relaxed text-text-secondary">
          HTTP-native paywall using macaroon tokens and payment proofs. No accounts, no subscriptions.
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="group rounded-2xl p-8 transition-colors duration-200 hover:bg-surface-2/50">
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-success/10 text-success">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <h3 class="mb-2 text-lg font-semibold">Privacy First</h3>
        <p class="text-sm leading-relaxed text-text-secondary">
          No sign-up required. Connect your Fiber node and pay directly — your data stays yours.
        </p>
      </div>
    </div>
  </section>
</Layout>
