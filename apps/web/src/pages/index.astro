---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config';
import { loadAllArticles } from '../lib/articles';

const articles = loadAllArticles();
articles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title={`${siteConfig.title} — ${siteConfig.tagline}`}>
  <div class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <section class="mb-16">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{siteConfig.tagline}</h1>
      <p class="mt-3 text-lg text-text-muted" style="font-family: var(--font-serif); font-style: italic;">
        {siteConfig.description}
      </p>
    </section>

    {articles.length === 0 && (
      <div class="rounded-xl border border-border px-6 py-12 text-center">
        <p class="text-text-muted">No articles yet. Check back soon.</p>
      </div>
    )}

    {articles.length > 0 && (
      <section>
        {articles.map((article) => (
          <a href={`/articles/${article.id}`} class="blog-card group">
            <div class="flex items-start justify-between gap-4">
              <h2 class="blog-card-title">{article.title}</h2>
              {article.price > 0 && (
                <span class="mt-0.5 shrink-0 rounded-full bg-accent-soft px-2.5 py-0.5 text-xs font-semibold text-accent">
                  {article.price} CKB
                </span>
              )}
            </div>

            <p class="blog-card-preview">{article.preview}</p>

            <div class="blog-card-meta">
              <time>{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
              {article.tags && article.tags.length > 0 && (
                <>
                  <span class="dot" />
                  <span>{article.tags.slice(0, 3).join(', ')}</span>
                </>
              )}
            </div>
          </a>
        ))}
      </section>
    )}
  </div>
</Layout>