---
import Layout from '../../layouts/Layout.astro';

let articles: any[] = [];
let fetchError: string | null = null;

try {
  const response = await fetch('http://localhost:3001/api/articles');
  if (!response.ok) throw new Error(`Server returned ${response.status}`);
  articles = await response.json();
} catch (e) {
  fetchError = 'Unable to load articles. The content server may be offline.';
}
---

<Layout title="Articles — Fiber L402">
  <div class="mx-auto max-w-5xl px-6 py-12 sm:py-16">
    <!-- Page Header -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Articles</h1>
      <p class="mt-2 text-text-secondary">
        In-depth content about Fiber Network, CKB, and the L402 protocol.
      </p>
    </div>

    {fetchError && (
      <div class="rounded-xl border border-error/20 bg-error/5 px-6 py-8 text-center">
        <p class="text-error">{fetchError}</p>
        <a href="/articles" class="mt-3 inline-block text-sm text-accent hover:text-accent-hover no-underline">
          Try again →
        </a>
      </div>
    )}

    {!fetchError && articles.length === 0 && (
      <div class="rounded-xl border border-border bg-surface-2/50 px-6 py-12 text-center">
        <p class="text-text-muted">No articles available yet. Check back soon.</p>
      </div>
    )}

    {!fetchError && articles.length > 0 && (
      <div class="grid gap-4 sm:grid-cols-2">
        {articles.map((article: any) => (
          <a
            href={`/articles/${article.id}`}
            class="group relative flex flex-col rounded-2xl border border-border bg-surface-1 p-6 no-underline transition-all duration-200 hover:border-border-hover hover:bg-surface-2/50 hover:shadow-lg hover:shadow-black/10"
          >
            <!-- Price badge -->
            <div class="mb-4 inline-flex self-start rounded-lg bg-accent/10 px-2.5 py-1 text-xs font-semibold text-accent">
              {article.price} CKB
            </div>

            <h2 class="mb-2 text-lg font-semibold leading-snug text-text-primary group-hover:text-accent transition-colors duration-200">
              {article.title}
            </h2>

            <p class="mb-4 flex-1 text-sm leading-relaxed text-text-secondary line-clamp-3">
              {article.preview}
            </p>

            <div class="flex items-center justify-between text-xs text-text-muted">
              <span>{article.author}</span>
              <time>{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            </div>

            <!-- Hover arrow -->
            <div class="absolute right-5 top-6 text-text-muted opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
