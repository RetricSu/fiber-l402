---
import Layout from '../../layouts/Layout.astro';
import { PaymentGate } from '../../components/PaymentGate.tsx';
import { siteConfig } from '../../config';

const { id } = Astro.params;
let article = null;
let error = null;

try {
  const response = await fetch(`${siteConfig.apiBaseUrl}/api/articles/${id}`);
  if (!response.ok) {
    if (response.status === 404) throw new Error('Article not found');
    throw new Error(`Server error: ${response.status}`);
  }
  article = await response.json();
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load article';
  if (error.includes('fetch') || error.includes('ECONNREFUSED')) {
    error = 'The content server is currently unreachable. Please try again later.';
  }
}

// Estimate reading time (~200 words/min for English)
function estimateReadingTime(preview: string): string {
  // Since we only have the preview, give a rough estimate
  return '5 min read';
}
---

<Layout title={article?.title ? `${article.title} — ${siteConfig.title}` : `Error — ${siteConfig.title}`} description={article?.preview}>
  <div class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    {error && (
      <div class="rounded-2xl border border-error/20 bg-error/5 px-8 py-12 text-center">
        <div class="mb-3 text-4xl">⚠</div>
        <h2 class="mb-2 text-xl font-semibold text-error">Something went wrong</h2>
        <p class="mb-6 text-text-secondary">{error}</p>
        <a
          href="/articles"
          class="inline-flex items-center gap-2 rounded-lg bg-surface-3 px-4 py-2.5 text-sm font-medium text-text-primary no-underline transition-colors hover:bg-surface-4"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to archive
        </a>
      </div>
    )}

    {!error && article && (
      <>
        <!-- Breadcrumb -->
        <nav class="mb-8">
          <a
            href="/articles"
            class="inline-flex items-center gap-1.5 text-sm text-text-muted no-underline transition-colors hover:text-text-primary"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Archive
          </a>
        </nav>

        <!-- Article Header -->
        <header class="mb-10">
          <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl" style="line-height: 1.3;">
            {article.title}
          </h1>

          <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-text-muted">
            <time>{new Date(article.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
            <span class="h-1 w-1 rounded-full bg-text-muted" />
            <span>{estimateReadingTime(article.preview)}</span>
            {article.price > 0 && (
              <>
                <span class="h-1 w-1 rounded-full bg-text-muted" />
                <span class="text-accent font-medium">{article.price} CKB</span>
              </>
            )}
          </div>

          <!-- Tags -->
          {article.tags && article.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {article.tags.map((tag: string) => (
                <a href={`/articles?tag=${encodeURIComponent(tag)}`} class="tag">
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        <!-- Preview as natural article opening -->
        <div id="article-preview" class="mb-0" style="font-family: var(--font-serif); font-size: 1.125rem; line-height: 1.9; color: var(--color-text-secondary);">
          <p>{article.preview}</p>
        </div>

        <!-- Payment Gate + Content -->
        <PaymentGate
          client:load
          articleId={id!}
          price={article.price}
        />
      </>
    )}
  </div>
</Layout>
