---
import Layout from '../../layouts/Layout.astro';
import { PaymentGate } from '../../components/PaymentGate.tsx';

const { id } = Astro.params;
let article = null;
let error = null;

try {
  const response = await fetch(`http://localhost:3001/api/articles/${id}`);
  if (!response.ok) {
    if (response.status === 404) throw new Error('Article not found');
    throw new Error(`Server error: ${response.status}`);
  }
  article = await response.json();
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load article';
  if (error.includes('fetch') || error.includes('ECONNREFUSED')) {
    error = 'The content server is currently unreachable. Please try again later.';
  }
}
---

<Layout title={article?.title || 'Error — Fiber L402'}>
  <div class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    {error && (
      <div class="rounded-2xl border border-error/20 bg-error/5 px-8 py-12 text-center">
        <div class="mb-3 text-4xl">⚠</div>
        <h2 class="mb-2 text-xl font-semibold text-error">Something went wrong</h2>
        <p class="mb-6 text-text-secondary">{error}</p>
        <a
          href="/articles"
          class="inline-flex items-center gap-2 rounded-lg bg-surface-3 px-4 py-2.5 text-sm font-medium text-text-primary no-underline transition-colors hover:bg-surface-4"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to articles
        </a>
      </div>
    )}

    {!error && article && (
      <>
        <!-- Breadcrumb -->
        <nav class="mb-8">
          <a
            href="/articles"
            class="inline-flex items-center gap-1.5 text-sm text-text-muted no-underline transition-colors hover:text-text-secondary"
          >
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            All articles
          </a>
        </nav>

        <!-- Article Header -->
        <header class="mb-10">
          <div class="mb-4 flex flex-wrap gap-2">
            {article.tags.map((tag: string) => (
              <span class="rounded-lg bg-surface-3 px-2.5 py-1 text-xs font-medium text-text-secondary">
                {tag}
              </span>
            ))}
          </div>

          <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
            {article.title}
          </h1>

          <div class="mt-4 flex items-center gap-3 text-sm text-text-muted">
            <span>{article.author}</span>
            <span class="h-1 w-1 rounded-full bg-text-muted" />
            <time>{new Date(article.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
          </div>
        </header>

        <!-- Preview -->
        <div class="mb-8 rounded-xl border border-border bg-surface-1 p-6">
          <p class="text-base leading-relaxed text-text-secondary italic">
            {article.preview}
          </p>
        </div>

        <!-- Payment Gate + Content -->
        <PaymentGate
          client:load
          articleId={id!}
          price={article.price}
        />
      </>
    )}
  </div>
</Layout>

<style>
  /* No scoped styles needed — article content typography is in global.css */
</style>
