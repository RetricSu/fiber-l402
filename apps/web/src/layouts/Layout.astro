---
import '../styles/global.css';
import { FiberConnectButton } from '../components/FiberConnectButton.tsx';
import { siteConfig } from '../config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = siteConfig.description } = Astro.props;
const siteName = siteConfig.title;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: DM Sans for UI, Lora for long-form reading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Lora:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-border bg-surface-1/90 backdrop-blur-lg">
      <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-6">
        <!-- Blog name -->
        <a href="/" class="flex items-center gap-2 text-text-primary no-underline transition-opacity duration-150 hover:opacity-70">
          <span class="text-lg font-bold tracking-tight">{siteName}</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden items-center gap-1 sm:flex">
          <a href="/" class="rounded-lg px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-surface-2 hover:text-text-primary no-underline">
            Home
          </a>
          <a href="/articles" class="rounded-lg px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-surface-2 hover:text-text-primary no-underline">
            Archive
          </a>
          <a href="/about" class="rounded-lg px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-surface-2 hover:text-text-primary no-underline">
            About
          </a>
        </nav>

        <!-- Right side: Fiber connect + mobile menu -->
        <div class="flex items-center gap-3">
          <FiberConnectButton client:load />

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-btn"
            class="flex h-9 w-9 items-center justify-center rounded-lg text-text-secondary transition-colors hover:bg-surface-2 sm:hidden cursor-pointer"
            aria-label="Open menu"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav drawer -->
      <div id="mobile-menu" class="hidden border-t border-border bg-surface-1 px-6 py-4 sm:hidden">
        <nav class="flex flex-col gap-1">
          <a href="/" class="rounded-lg px-3 py-2.5 text-sm font-medium text-text-secondary hover:bg-surface-2 hover:text-text-primary no-underline">Home</a>
          <a href="/articles" class="rounded-lg px-3 py-2.5 text-sm font-medium text-text-secondary hover:bg-surface-2 hover:text-text-primary no-underline">Archive</a>
          <a href="/about" class="rounded-lg px-3 py-2.5 text-sm font-medium text-text-secondary hover:bg-surface-2 hover:text-text-primary no-underline">About</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border">
      <div class="mx-auto max-w-3xl px-6 py-10">
        <div class="flex flex-col items-center gap-4 text-center">
          <div class="flex items-center gap-4">
            <!-- GitHub -->
            <a href={siteConfig.github} target="_blank" rel="noopener" class="text-text-muted transition-colors hover:text-text-primary" aria-label="GitHub">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          </div>
          <p class="text-xs text-text-muted">
            Paid content powered by <a href="https://fiber.world" class="text-text-muted underline underline-offset-2 transition-colors hover:text-accent" target="_blank" rel="noopener">Fiber Network</a> L402
          </p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
