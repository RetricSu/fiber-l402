---
import '../styles/global.css';
import { FiberConnectButton } from '../components/FiberConnectButton.tsx';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-border bg-surface-0/80 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 text-text-primary no-underline transition-opacity duration-150 hover:opacity-80">
          <svg class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <span class="text-lg font-semibold tracking-tight">Fiber L402</span>
        </a>

        <!-- Nav -->
        <nav class="hidden items-center gap-1 sm:flex">
          <a href="/" class="rounded-lg px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-surface-2 hover:text-text-primary no-underline">
            Home
          </a>
          <a href="/articles" class="rounded-lg px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-150 hover:bg-surface-2 hover:text-text-primary no-underline">
            Articles
          </a>
        </nav>

        <!-- Connect Button -->
        <FiberConnectButton client:load />
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border bg-surface-1/50">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
        <p class="text-sm text-text-muted">
          Powered by <a href="https://fiber.nervos.org" class="text-accent hover:text-accent-hover transition-colors no-underline" target="_blank" rel="noopener">Fiber Network</a> &amp; L402
        </p>
        <p class="text-sm text-text-muted">
          Pay-per-article content
        </p>
      </div>
    </footer>
  </body>
</html>
