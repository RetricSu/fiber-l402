{
  "name": "@fiber-l402/root",
  "private": true,
  "version": "0.0.0",
  "description": "L402 Payment Proxy on Fiber Network - Monorepo",
  "license": "MIT",
  "author": "Fiber L402 Team",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project packages/*",
    "test:integration": "vitest run --project apps/proxy",
    "test:e2e": "echo 'E2E tests use Playwright'",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tsconfig/node20": "^20.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
